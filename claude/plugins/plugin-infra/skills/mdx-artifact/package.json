{
  "name": "mdx-artifact",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "把 MDX（markdown + 可扩展组件）渲染成自包含、可离线的富 HTML 产物。构建期 React SSG，运行时零框架；组件注册表面向扩展（OCP）。",
  "scripts": {
    "preview": "node scripts/serve.mjs",
    "render": "node scripts/render.mjs",
    "build:css": "tailwindcss -i src/styles/tailwind.css -o .cache/tailwind.css"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0"
  }
}
